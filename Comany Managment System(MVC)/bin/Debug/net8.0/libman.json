{
  "version": "1.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "bootstrap-icons@1.11.3",
      "destination": "wwwroot/bootstrap-icons/",
      "files": [
        "font/bootstrap-icons.css",
        "font/bootstrap-icons.min.css"
      ]
    },
    {
      "library": "sweetalert2@11.14.4",
      "destination": "wwwroot/sweetalert2/",
      "files": [
        "sweetalert2.min.js",
        "sweetalert2.min.css",
        "sweetalert2.esm.min.js"
      ]
    },
    {
      "library": "select2@4.0.13",
      "destination": "wwwroot/select2/"
    }
  ]
}